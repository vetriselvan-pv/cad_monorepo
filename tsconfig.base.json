{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@org/source"],
    "noUncheckedSideEffectImports": false,
    "types": ["*"],
    "paths": {
      "@cad/core": ["./packages/core/src/index.ts"],
      "@cad/angular": ["./packages/angular/src/index.ts"],
      "@cad/react": ["./packages/react/src/index.ts"],
      "@cad/vue": ["./packages/vue/src/index.ts"]
    }
  }
}
